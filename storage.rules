rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Blog uploads — authenticated admins can write, anyone can read
    match /blog/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Block everything else by default
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
